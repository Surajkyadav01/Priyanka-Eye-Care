rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow operations on the appointments collection
    match /appointments/{appointmentId} {
      // Patients create appointments. Schema validation ensures safety.
      allow create: if request.resource.data.keys().hasAll(['id', 'name', 'phone', 'service', 'doctor', 'date', 'time', 'status', 'createdAt', 'isRead'])
        && request.resource.data.name is string
        && request.resource.data.phone is string
        && request.resource.data.service is string
        && request.resource.data.doctor is string
        && request.resource.data.date is string
        && request.resource.data.time is string
        && request.resource.data.status in ['pending', 'accepted', 'rejected']
        && request.resource.data.isRead is bool;

      // Allow read, update, delete for backend operations
      allow read, update, delete: if true;
    }
  }
}
