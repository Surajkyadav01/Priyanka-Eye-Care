{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "An appointment booked by a patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "service": { "type": "string" },
        "doctor": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "name", "phone", "service", "doctor", "date", "time", "status", "createdAt", "isRead"]
    }
  },
  "firestore": {
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of patient appointments"
    }
  }
}
